# Server
PORT=3000

# App DB
# Use :memory: for ephemeral runtime, or a file path for persistence.
DB_PATH=:memory:

# Optional external/persistent HCM mock base URL
# If empty, the app uses in-memory HCM behavior.
HCM_BASE_URL=

# HCM mock server settings (used by test/mocks/* utilities)
HCM_MOCK_PORT=4010
HCM_MOCK_DB_PATH=./test/mocks/data/hcm.sqlite
